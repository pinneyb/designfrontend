---
import Layout from '../layouts/Layout.astro';
import SectionLabel from '../components/SectionLabel.astro';
---

<Layout
  title="Contact | Kate Pinney Interiors"
  description="Get in touch with Kate Pinney Interiors to start your Denver residential interior design project."
>
  <section class="max-w-6xl mx-auto px-6 py-20 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">

      <!-- Left: contact info -->
      <div>
        <SectionLabel label="Reach Out" />
        <h2 class="font-display font-light text-[1.75rem] md:text-[3rem] leading-[1.15] mb-8">
          Let's Connect
        </h2>

        <div class="space-y-5 font-body font-light text-base leading-[1.7]">
          <div>
            <span class="eyebrow block mb-1">Email</span>
            <a href="mailto:kate@katepinneyinteriors.com" class="text-text hover:text-accent-dark transition-colors">
              kate@katepinneyinteriors.com
            </a>
          </div>
          <div>
            <span class="eyebrow block mb-1">Phone</span>
            <a href="tel:7201234567" class="text-text hover:text-accent-dark transition-colors">
              720-123-4567
            </a>
          </div>
          <div>
            <span class="eyebrow block mb-1">Instagram</span>
            <a
              href="https://www.instagram.com/katepinney_interiors"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text hover:text-accent-dark transition-colors"
            >
              @katepinney_interiors
            </a>
          </div>
          <div>
            <span class="eyebrow block mb-1">Pinterest</span>
            <a
              href="https://www.pinterest.com/katepinney_interiors"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text hover:text-accent-dark transition-colors"
            >
              @katepinney_interiors
            </a>
          </div>
        </div>
      </div>

      <!-- Right: contact form -->
      <!-- Action endpoint is driven by PUBLIC_FORMSPREE_ENDPOINT env var.
           To swap the backend later, update only the fetch URL in the script below. -->
      <div>
        <SectionLabel label="Send a Message" />

        <form id="contact-form" class="space-y-6" novalidate>
          <div>
            <label for="name" class="eyebrow block mb-2">Name <span class="text-accent-dark">*</span></label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="w-full border border-divider bg-transparent px-4 py-3 font-body font-light text-base text-text placeholder:text-accent focus:outline-none focus:border-accent-dark transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="eyebrow block mb-2">Email <span class="text-accent-dark">*</span></label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full border border-divider bg-transparent px-4 py-3 font-body font-light text-base text-text placeholder:text-accent focus:outline-none focus:border-accent-dark transition-colors"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <label for="phone" class="eyebrow block mb-2">Phone <span class="text-muted">(optional)</span></label>
            <input
              id="phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              class="w-full border border-divider bg-transparent px-4 py-3 font-body font-light text-base text-text placeholder:text-accent focus:outline-none focus:border-accent-dark transition-colors"
              placeholder="720-555-0100"
            />
          </div>

          <div>
            <label for="message" class="eyebrow block mb-2">Tell me about your project <span class="text-accent-dark">*</span></label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full border border-divider bg-transparent px-4 py-3 font-body font-light text-base text-text placeholder:text-accent focus:outline-none focus:border-accent-dark transition-colors resize-none"
              placeholder="Share a bit about your space, your timeline, and what you're hoping to create…"
            ></textarea>
          </div>

          <!-- Inline feedback messages -->
          <div id="form-success" class="hidden font-body font-light text-sm text-accent-dark py-3 px-4 border border-divider">
            Thank you — Kate will be in touch soon.
          </div>
          <div id="form-error" class="hidden font-body font-light text-sm text-red-600 py-3 px-4 border border-red-200">
            Something went wrong. Please try again or email kate@katepinneyinteriors.com directly.
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="btn-outline-dark w-full md:w-auto"
          >
            Send Message
          </button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<script>
  const form        = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg  = document.getElementById('form-success')!;
  const errorMsg    = document.getElementById('form-error')!;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;

  // Endpoint is injected at build time via Astro's env handling.
  // Swap this URL when moving away from Formspree.
  const endpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT as string;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    if (!endpoint) {
      errorMsg.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const data = new FormData(form);
      const res  = await fetch(endpoint, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successMsg.classList.remove('hidden');
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
