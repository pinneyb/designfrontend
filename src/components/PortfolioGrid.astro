---
interface PortfolioItem {
  src: string;
  alt: string;
  name: string;
  aspectClass?: string;
}

interface Props {
  items: PortfolioItem[];
  columns?: 2 | 3;
}

const { items, columns = 3 } = Astro.props;
const gridClass = columns === 2
  ? 'grid-cols-1 md:grid-cols-2'
  : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';
---

<div class={`grid ${gridClass} gap-4`}>
  {items.map(item => (
    <div class="group relative overflow-hidden">
      <img
        src={item.src}
        alt={item.alt}
        class={`w-full object-cover transition-transform duration-500 group-hover:scale-105 ${item.aspectClass ?? 'aspect-square'}`}
        loading="lazy"
      />
      <!-- Hover overlay with project name -->
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-300 flex items-end">
        <span class="eyebrow text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 p-5">
          {item.name}
        </span>
      </div>
    </div>
  ))}
</div>
